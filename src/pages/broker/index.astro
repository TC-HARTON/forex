---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/brokers.json';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://tcharton.com/' },
    { '@type': 'ListItem', position: 2, name: 'Broker', item: 'https://tcharton.com/broker/' },
  ],
};

// ItemList (推奨トップ3 / 構造化データ)
const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '日本居住者が口座開設できる海外 FX ブローカー トップ3 (XAUUSD 裁量向け)',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: data.recommended.map((b) => ({
    '@type': 'ListItem',
    position: b.rank,
    name: b.name,
    url: 'https://tcharton.com' + (b.detail_url || '/broker/'),
  })),
};

const extraJsonLd = `<script type="application/ld+json">${JSON.stringify(breadcrumbJsonLd)}</script><script type="application/ld+json">${JSON.stringify(itemListJsonLd)}</script>`;

const top3 = data.recommended;
const caution = data.caution;
const stars = (n) => (n == null ? '—' : '★'.repeat(Math.round(n)) + '☆'.repeat(5 - Math.round(n)));
const rankColor = { 1: 'teal', 2: 'indigo', 3: 'amber' };
const accent = {
  teal:   { bar: 'bg-teal-700', chip: 'bg-teal-700 text-white', border: 'border-l-teal-700', soft: 'bg-teal-50 text-teal-700' },
  indigo: { bar: 'bg-indigo-500', chip: 'bg-indigo-500 text-white', border: 'border-l-indigo-500', soft: 'bg-indigo-50 text-indigo-600' },
  amber:  { bar: 'bg-amber-500', chip: 'bg-amber-500 text-white', border: 'border-l-amber-500', soft: 'bg-amber-50 text-amber-600' },
};
---

<BaseLayout
  title="日本から使える海外 FX ブローカー トップ3 | 世界の評価サイト検証 | T.C.HARTON"
  description="日本居住者が口座開設できる海外 FX を、ForexBrokers.com・Trustpilot・FXEmpire 等 世界の評価サイトの一次情報で検証。XAUUSD 裁量向けトップ3 (IC Markets / Titan FX / AXIORY) を出典付きで比較。XM が推奨されがちな実態と非推奨ブローカーの理由も明示。"
  keywords="海外FX ブローカー 比較,日本から使える海外FX,IC Markets 評判,XM 推奨 実態,XAUUSD ブローカー,海外FX おすすめ トップ3,海外FX 非推奨"
  canonicalPath="/broker/"
  ogImage="/og/broker.png"
  extraJsonLd={extraJsonLd}
>
  <nav aria-label="パンくず" class="text-xs text-dark-700 mb-6">
    <a href="/" class="hover:text-teal-700">ホーム</a>
    <span aria-hidden="true" class="mx-2">/</span>
    <span aria-current="page">Broker</span>
  </nav>

  <header>
    <p class="text-xs font-display font-bold tracking-widest uppercase text-teal-700">Broker Review</p>
    <h1 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-dark-900">日本から使える海外 FX ブローカー トップ3</h1>
    <p id="summary" class="mt-4 text-dark-700 leading-relaxed max-w-2xl">
      世界の独立した評価サイト (<strong class="text-dark-900">ForexBrokers.com / Trustpilot / FXEmpire / DailyForex</strong>) の一次情報と各社公式を突き合わせ、
      <strong class="text-dark-900">「日本居住者が正規に口座開設でき、MT4/MT5 が使え、第三者評価が一貫して高い」</strong>の 3 軸で XAUUSD 裁量向けに厳選しました。
      国内サイトで定番の XM が「推奨」されがちな実態と、非推奨ブローカーの理由も出典付きで明示します。
    </p>
  </header>

  <!-- アフィリエイト開示 -->
  <section class="mt-6 p-4 border-l-4 border-amber-400 bg-amber-50 text-xs sm:text-sm text-dark-800 leading-relaxed rounded-r">
    <p class="font-semibold mb-1">⚠ アフィリエイト開示 (景表法 §5 / 特商法準拠)</p>
    <p>{data._affiliate_disclosure}</p>
  </section>

  <!-- 選定軸 -->
  <section class="reveal mt-8 p-6 border border-dark-200 border-l-4 border-l-teal-700 rounded-xl bg-white">
    <h2 class="font-display text-lg font-bold text-dark-900">どう選んだか — 3 つの選定軸</h2>
    <p class="mt-3 text-sm text-dark-700 leading-relaxed">{data._selection_axis}</p>
    <div class="mt-4 grid sm:grid-cols-3 gap-3 text-sm">
      <div class="p-4 rounded-lg bg-dark-50 border border-dark-200">
        <p class="font-display font-bold text-dark-900">① 日本から開設できる</p>
        <p class="mt-1 text-dark-700 leading-relaxed">世界トップ評価でも日本居住者が開設不可な業者 (Pepperstone / FP Markets 等) は対象外。</p>
      </div>
      <div class="p-4 rounded-lg bg-dark-50 border border-dark-200">
        <p class="font-display font-bold text-dark-900">② MT4 / MT5 対応</p>
        <p class="mt-1 text-dark-700 leading-relaxed">当サイトの <a href="/dashboard/" class="underline text-teal-700">MT5_Python ダッシュボード</a> と連携できること。</p>
      </div>
      <div class="p-4 rounded-lg bg-dark-50 border border-dark-200">
        <p class="font-display font-bold text-dark-900">③ 第三者評価が一貫</p>
        <p class="mt-1 text-dark-700 leading-relaxed">海外の独立評価サイトで高評価かつ、信頼性に重大な疑義がないこと。</p>
      </div>
    </div>
  </section>

  <!-- 「口座種別でコストが激変」前提 -->
  <section class="reveal mt-8 p-6 border border-dark-200 border-l-4 border-l-rose-500 rounded-xl bg-white">
    <div class="flex items-center gap-2.5">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-rose-100 text-rose-700" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      </span>
      <h2 class="font-display text-lg font-bold text-dark-900">前提 — 「スプレッド○ pips」は口座種別で激変する</h2>
    </div>
    <p class="mt-3 text-sm text-dark-700 leading-relaxed">{data._account_note}</p>
    <div class="mt-4 grid sm:grid-cols-2 gap-3 text-sm">
      <div class="p-4 rounded-lg bg-dark-50 border border-dark-200">
        <p class="font-display font-bold text-dark-900">スタンダード口座</p>
        <p class="mt-1 text-dark-700 leading-relaxed">取引手数料 <strong>無料</strong>。その代わりスプレッドが広め (EUR/USD 概ね 1.0〜2.0 pips)。</p>
      </div>
      <div class="p-4 rounded-lg bg-teal-50 border border-teal-200">
        <p class="font-display font-bold text-dark-900">低スプレッド口座 (Raw / Zero / 極 / Blade / Nano)</p>
        <p class="mt-1 text-dark-700 leading-relaxed">スプレッドが狭い (0.0〜0.4 pips) 代わりに<strong>往復手数料</strong> ($6〜10/lot 程度) が別途かかる。</p>
      </div>
    </div>
    <p class="mt-3 text-xs text-dark-600">{data._sources_note}</p>
  </section>

  <!-- ===== 推奨トップ3 ===== -->
  <section aria-label="推奨トップ3" class="mt-12">
    <h2 class="font-display text-2xl font-bold text-dark-900 pb-2 border-b-2 border-teal-700">推奨トップ3 (日本居住者が開設可)</h2>
    <div class="mt-8 space-y-6">
      {top3.map((b, i) => {
        const a = accent[rankColor[b.rank]];
        return (
        <article class="reveal card-lift relative overflow-hidden border border-dark-200 border-l-4 {a.border} rounded-xl bg-white" data-reveal-delay={i * 90}>
          <span class={`absolute inset-x-0 top-0 h-1 ${a.bar} opacity-80`} aria-hidden="true"></span>
          <div class="p-6 sm:p-7">
            <!-- ヘッダ -->
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <span class={`inline-flex h-10 w-10 items-center justify-center rounded-lg font-display font-extrabold text-lg ${a.chip}`}>{b.rank}</span>
                <div>
                  <h3 class="font-display text-xl font-bold text-dark-900">{b.name}</h3>
                  <p class="text-xs text-dark-600 mt-0.5">{b.tagline}</p>
                </div>
              </div>
              <div class="text-right text-xs text-dark-600">
                {b.rating_fb && <p>ForexBrokers.com <strong class="text-dark-900">{b.rating_fb}</strong> <span class="text-dark-400">(TS {b.rating_fb_trustscore})</span></p>}
                <p class="mt-0.5">Trustpilot <strong class="text-dark-900">{b.rating_tp ?? '—'}</strong> <span class="text-amber-500" aria-hidden="true">{stars(b.rating_tp)}</span></p>
                <p class="mt-0.5 text-dark-500">{b.tp_reviews}</p>
              </div>
            </div>

            <!-- スペック -->
            <dl class="mt-5 grid sm:grid-cols-2 gap-x-6 gap-y-2 text-xs">
              <div class="flex gap-2"><dt class="w-28 shrink-0 text-dark-500">日本居住者</dt><dd class="text-dark-800">{b.japan_status}</dd></div>
              <div class="flex gap-2"><dt class="w-28 shrink-0 text-dark-500">規制 / エンティティ</dt><dd class="text-dark-800">{b.japan_entity}</dd></div>
              <div class="flex gap-2"><dt class="w-28 shrink-0 text-dark-500">スタンダード</dt><dd class="text-dark-800">{b.standard_eurusd}</dd></div>
              <div class="flex gap-2"><dt class="w-28 shrink-0 text-dark-500">低スプレッド</dt><dd class="text-dark-800">{b.low_account}</dd></div>
              <div class="flex gap-2"><dt class="w-28 shrink-0 text-dark-500">XAUUSD</dt><dd class="text-dark-800">{b.xauusd}</dd></div>
              <div class="flex gap-2"><dt class="w-28 shrink-0 text-dark-500">最小入金 / レバ</dt><dd class="text-dark-800 font-mono">${b.min_deposit_usd} / {b.max_leverage}</dd></div>
              <div class="flex gap-2"><dt class="w-28 shrink-0 text-dark-500">プラットフォーム</dt><dd class="text-dark-800">{b.platforms}</dd></div>
              <div class="flex gap-2"><dt class="w-28 shrink-0 text-dark-500">日本語サポート</dt><dd class="text-dark-800">{b.jp_support}</dd></div>
            </dl>

            {b.awards && (
              <p class="mt-4 text-xs text-dark-700"><span class={`inline-block px-2 py-0.5 rounded font-display font-bold mr-2 ${a.soft}`}>受賞</span>{b.awards}</p>
            )}

            <!-- 長所 / 注意点 (公平表示) -->
            <div class="mt-5 grid sm:grid-cols-2 gap-4">
              <div class="p-4 rounded-lg bg-teal-50/50 border border-teal-200">
                <p class="font-display font-semibold text-sm text-dark-900">👍 長所</p>
                <ul class="mt-2 space-y-1 text-sm text-dark-700">
                  {b.pros.map((p) => <li>• {p}</li>)}
                </ul>
              </div>
              <div class="p-4 rounded-lg bg-amber-50/50 border border-amber-200">
                <p class="font-display font-semibold text-sm text-dark-900">⚠ 注意点 (公平のため明記)</p>
                <ul class="mt-2 space-y-1 text-sm text-dark-700">
                  {b.cautions.map((c) => <li>• {c}</li>)}
                </ul>
              </div>
            </div>

            <!-- 出典 + CTA -->
            <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2">
              {b.detail_url && (
                <a href={b.detail_url} class="btn-pop inline-flex items-center gap-2 px-5 py-2.5 bg-teal-700 text-white rounded-md font-bold text-sm hover:bg-teal-800">
                  詳細レビューを読む
                  <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
              )}
              <a href={b.official_url} rel="noopener noreferrer" target="_blank" class="inline-flex items-center gap-1.5 text-sm font-bold text-teal-700">
                公式サイトで最新条件を確認
                <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-dark-500">
              <span class="font-semibold">出典:</span>
              {b.sources.map((s) => (
                <a href={s.url} rel="noopener noreferrer" target="_blank" class="underline hover:text-teal-700">{s.label} ↗</a>
              ))}
            </div>
          </div>
        </article>
        );
      })}
    </div>
  </section>

  <!-- 比較表 (トップ3) -->
  <section class="mt-12">
    <h2 class="font-display text-xl font-bold text-dark-900 pb-2 border-b-2 border-teal-700">トップ3 スペック早見表</h2>
    <div class="mt-5 border border-dark-200 rounded-xl bg-white overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="text-xs text-dark-700 bg-dark-50">
          <tr>
            <th class="text-left px-4 py-3 font-display font-semibold">ブローカー</th>
            <th class="text-left px-4 py-3 font-display font-semibold">評価 (FB / TP)</th>
            <th class="text-left px-4 py-3 font-display font-semibold">スタンダード</th>
            <th class="text-left px-4 py-3 font-display font-semibold">低スプレッド口座</th>
            <th class="text-right px-4 py-3 font-display font-semibold">最小入金</th>
            <th class="text-left px-4 py-3 font-display font-semibold">規制</th>
          </tr>
        </thead>
        <tbody>
          {top3.map((b) => (
            <tr class="border-t border-dark-100 hover:bg-teal-50/30 transition">
              <td class="px-4 py-3 align-top">
                <span class="font-bold text-dark-900">{b.rank}. {b.name}</span>
                <p class="text-xs text-dark-500 mt-0.5">{b.platforms}</p>
              </td>
              <td class="px-4 py-3 align-top text-xs text-dark-700 whitespace-nowrap">
                FB {b.rating_fb ?? '—'} / TP {b.rating_tp ?? '—'}
                <br /><span class="text-amber-500" aria-hidden="true">{stars(b.rating_tp)}</span>
              </td>
              <td class="px-4 py-3 align-top text-xs text-dark-700">{b.standard_eurusd}</td>
              <td class="px-4 py-3 align-top text-xs text-dark-700">{b.low_account}</td>
              <td class="px-4 py-3 align-top text-right font-mono text-dark-900 whitespace-nowrap">${b.min_deposit_usd}</td>
              <td class="px-4 py-3 align-top text-xs text-dark-700">{b.regulation}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-dark-600">FB = ForexBrokers.com (5 段階 / Trust Score 99 点満点) / TP = Trustpilot TrustScore (2026-06-03 実測・★は四捨五入)。値は変動制で、最新は各公式・各評価サイトでご確認ください。</p>
  </section>

  <!-- 非推奨・注意ブローカーへの導線 -->
  <section aria-label="非推奨ブローカー" class="reveal mt-12 p-6 sm:p-7 border-2 border-rose-300 rounded-xl bg-rose-50/40">
    <div class="flex items-center gap-2.5">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-rose-100 text-rose-700" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg>
      </span>
      <h2 class="font-display text-lg font-bold text-dark-900">推奨しなかったブローカーと、その理由</h2>
    </div>
    <p class="mt-3 text-sm text-dark-700 leading-relaxed">
      国内サイトで定番の <strong class="text-dark-900">XM</strong> をなぜトップ3に入れなかったのか、
      <strong class="text-dark-900">Exness</strong> の注意点、世界トップ評価でも日本居住者が開設できない
      <strong class="text-dark-900">Pepperstone / FP Markets</strong> について、すべて出典付きで検証しています。
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      {caution.map((c) => (
        <span class="text-xs px-2.5 py-1 bg-white border border-rose-200 rounded text-dark-700">{c.name}</span>
      ))}
    </div>
    <a href="/broker/caution/" class="btn-pop mt-5 inline-flex items-center gap-2 px-5 py-2.5 bg-rose-600 text-white rounded-md font-bold text-sm hover:bg-rose-700">
      非推奨・注意ブローカーの検証を読む
      <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </section>

  <!-- 注意事項 -->
  <section class="mt-10 p-6 border border-dark-200 rounded-xl bg-white text-sm text-dark-700 leading-relaxed">
    <h2 class="font-display font-bold text-base text-dark-900 mb-3">比較の注意点</h2>
    <ul class="space-y-2">
      <li>• スプレッドは<strong class="text-dark-900">変動制</strong>で、相場急変時 (指標発表・early Tokyo 等) には大きく拡大します。表の値は平常時の代表値です。</li>
      <li>• 実質コスト = <strong class="text-dark-900">スプレッド + 往復手数料</strong>。低スプレッド口座は手数料込みで判断してください。</li>
      <li>• 海外 FX 業者は<strong class="text-dark-900">金融庁未登録</strong>です。利用は自己責任で、最新規約・税制 (雑所得 累進課税) をご確認ください。</li>
      <li>• 評価 (ForexBrokers.com / Trustpilot 等) は<strong class="text-dark-900">第三者サイトの値で変動</strong>します。本ページの順位は紹介料の有無で操作していません。</li>
      <li>• 本ページは投資助言ではなく、ツール (MT5) と組み合わせ可能なブローカーの<strong class="text-dark-900">比較情報</strong>です。</li>
    </ul>
  </section>

  <!-- 関連 -->
  <section class="mt-8 grid gap-4 md:grid-cols-2 text-sm">
    <a href="/docs/" class="reveal card-lift group flex items-start gap-4 p-5 border border-dark-200 border-l-4 border-l-teal-700 rounded-xl bg-white hover:border-dark-300">
      <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-teal-50 text-teal-700" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h7l-1 8 10-12h-7z"/></svg>
      </span>
      <span class="flex-1">
        <h3 class="font-display font-bold text-dark-900 group-hover:text-teal-700">MT5_Python クイックスタート</h3>
        <p class="mt-1.5 text-dark-600 leading-relaxed">どのブローカー口座でも使える MT5 + Python ダッシュボードの導入手順</p>
        <span class="mt-2 inline-flex items-center gap-1.5 font-bold text-teal-700">導入手順を見る<svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </span>
    </a>
    <a href="/legal/disclaimer/" class="reveal card-lift group flex items-start gap-4 p-5 border border-dark-200 border-l-4 border-l-amber-500 rounded-xl bg-white hover:border-dark-300" data-reveal-delay="80">
      <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-amber-50 text-amber-600" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v5c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M12 8v4M12 16h.01"/></svg>
      </span>
      <span class="flex-1">
        <h3 class="font-display font-bold text-dark-900 group-hover:text-teal-700">免責事項</h3>
        <p class="mt-1.5 text-dark-600 leading-relaxed">投資助言業 非該当宣言と損失リスク警告</p>
        <span class="mt-2 inline-flex items-center gap-1.5 font-bold text-teal-700">内容を確認する<svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </span>
    </a>
  </section>
</BaseLayout>

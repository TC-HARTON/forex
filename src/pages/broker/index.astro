---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/brokers.json';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://tcharton.com/' },
    { '@type': 'ListItem', position: 2, name: 'Broker', item: 'https://tcharton.com/broker/' },
  ],
};
const extraJsonLd = `<script type="application/ld+json">${JSON.stringify(breadcrumbJsonLd)}</script>`;

// 推奨 (IC Markets) を先頭に、以降は掲載順
const brokers = data.brokers;
const stars = (n: number | null) => (n == null ? '—' : '★'.repeat(Math.round(n)) + '☆'.repeat(5 - Math.round(n)));
---

<BaseLayout
  title="海外 FX ブローカー徹底比較 | スプレッド・評価・口コミ検証 | T.C.HARTON"
  description="IC Markets・XM・Exness・Titan FX・AXIORY を海外評価サイト (ForexBrokers.com / Trustpilot) と公式スプレッド表で徹底検証。口座種別ごとの EUR/USD スプレッド・評価・口コミ・規制を出典付きで比較。"
  keywords="海外FX ブローカー 比較,IC Markets 評判,XM スプレッド,海外FX おすすめ,XAUUSD ブローカー,FX 約定速度 スプレッド,海外FX 口コミ"
  canonicalPath="/broker/"
  ogImage="/og/broker.png"
  extraJsonLd={extraJsonLd}
>
  <nav aria-label="パンくず" class="text-xs text-dark-700 mb-6">
    <a href="/" class="hover:text-teal-700">ホーム</a>
    <span aria-hidden="true" class="mx-2">/</span>
    <span aria-current="page">Broker</span>
  </nav>

  <header>
    <p class="text-xs font-display font-bold tracking-widest uppercase text-teal-700">Broker Review</p>
    <h1 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-dark-900">海外 FX ブローカー徹底比較</h1>
    <p id="summary" class="mt-4 text-dark-700 leading-relaxed max-w-2xl">
      海外の評価サイト (ForexBrokers.com / Trustpilot) と各社公式スプレッド表を突き合わせ、主要 5 社を検証しました。
      XAUUSD 裁量で重要な<strong class="text-dark-900">「口座種別ごとの実質スプレッド」「約定」「規制」「評価・口コミ」</strong>を、出典付きで比較します。
    </p>
  </header>

  <!-- アフィリエイト開示 -->
  <section class="mt-6 p-4 border-l-4 border-amber-400 bg-amber-50 text-xs sm:text-sm text-dark-800 leading-relaxed rounded-r">
    <p class="font-semibold mb-1">⚠ アフィリエイト開示 (景表法 §5 / 特商法準拠)</p>
    <p>{data._affiliate_disclosure}</p>
  </section>

  <!-- 最重要の前提: 口座種別でコストが激変する -->
  <section class="reveal mt-8 p-6 border border-dark-200 border-l-4 border-l-rose-500 rounded-xl bg-white">
    <div class="flex items-center gap-2.5">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-rose-100 text-rose-700" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      </span>
      <h2 class="font-display text-lg font-bold text-dark-900">比較の前に — 「スプレッド○ pips」は口座種別で激変する</h2>
    </div>
    <p class="mt-3 text-sm text-dark-700 leading-relaxed">{data._account_note}</p>
    <div class="mt-4 grid sm:grid-cols-2 gap-3 text-sm">
      <div class="p-4 rounded-lg bg-dark-50 border border-dark-200">
        <p class="font-display font-bold text-dark-900">スタンダード口座</p>
        <p class="mt-1 text-dark-700 leading-relaxed">取引手数料 <strong>無料</strong>。その代わりスプレッドが広め (EUR/USD 概ね 1.0〜1.6 pips)。</p>
      </div>
      <div class="p-4 rounded-lg bg-teal-50 border border-teal-200">
        <p class="font-display font-bold text-dark-900">低スプレッド口座 (Raw / Zero / 極)</p>
        <p class="mt-1 text-dark-700 leading-relaxed">スプレッドが狭い (0.0〜0.4 pips) 代わりに<strong>往復手数料</strong> ($6〜7/lot 程度) が別途かかる。</p>
      </div>
    </div>
    <div class="mt-4 p-4 rounded-lg bg-amber-50 border border-amber-200 text-sm text-dark-800 leading-relaxed">
      <p class="font-display font-bold text-dark-900 mb-1">⚠ よくある誤解: 「XM は EUR/USD 1.0 pips」は不正確</p>
      <p>
        XM のスタンダード口座の EUR/USD は<strong>平均 約1.6 pips (変動制)</strong> です (ForexBrokers.com 2025 検証 / XMTrading 公式スプレッド表)。
        「1.0 pips」は最小値・宣伝上の起点であり、実測の代表値ではありません。XM で低コストを狙うなら<strong>手数料無料で平均 約0.7 pips の「KIWAMI極」口座</strong>が中心です。
        本ページではこの混同を避け、口座種別を分けて表記しています。
      </p>
    </div>
    <p class="mt-3 text-xs text-dark-600">{data._sources_note}</p>
  </section>

  <!-- 推奨: IC Markets feature card -->
  <section aria-label="推奨ブローカー" class="reveal mt-8 p-6 sm:p-8 border-2 border-teal-700 rounded-xl bg-teal-50/40">
    <div class="flex flex-wrap items-center gap-3">
      <span class="text-xs px-2 py-0.5 bg-teal-700 text-white rounded font-display font-bold">検証済み推奨</span>
      <h2 class="font-display font-bold text-xl text-dark-900">IC Markets — XAUUSD 裁量に最適な理由</h2>
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-4 text-sm">
      <span class="text-dark-700">ForexBrokers.com <strong class="text-dark-900">4.5/5</strong></span>
      <span class="text-amber-500" aria-hidden="true">{stars(4.5)}</span>
      <span class="text-dark-400">|</span>
      <span class="text-dark-700">Trustpilot <strong class="text-dark-900">約4.8/5</strong> (4万件超)</span>
    </div>
    <p class="mt-3 text-sm text-dark-700 leading-relaxed max-w-3xl">
      海外 15 サイト以上の一次情報で検証した結論。Raw Spread 口座の EUR/USD は<strong class="text-dark-900">平均 約0.1 pips + 往復手数料 約$7/lot</strong>、
      約定 40ms 未満・ASIC/CySEC の Tier-1 規制 2 つ・高い流動性。<strong class="text-dark-900">なぜ最適かを出典付きで解説</strong>しています。
    </p>
    <a href="/broker/icmarkets/" class="btn-pop mt-5 inline-flex items-center gap-2 px-5 py-2.5 bg-teal-700 text-white rounded-md font-bold text-sm hover:bg-teal-800">
      IC Markets の検証記事を読む
      <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </section>

  <!-- 比較表 (口座種別を分離) -->
  <section class="mt-10">
    <h2 class="font-display text-xl font-bold text-dark-900 pb-2 border-b-2 border-teal-700">スプレッド・評価 比較表</h2>
    <div class="mt-5 border border-dark-200 rounded-xl bg-white overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="text-xs text-dark-700 bg-dark-50">
          <tr>
            <th class="text-left px-4 py-3 font-display font-semibold">ブローカー</th>
            <th class="text-left px-4 py-3 font-display font-semibold">評価 (FB / TP)</th>
            <th class="text-left px-4 py-3 font-display font-semibold">スタンダード (EUR/USD)</th>
            <th class="text-left px-4 py-3 font-display font-semibold">低スプレッド口座</th>
            <th class="text-right px-4 py-3 font-display font-semibold">最小入金</th>
            <th class="text-right px-4 py-3 font-display font-semibold">最大レバ</th>
            <th class="text-left px-4 py-3 font-display font-semibold">規制</th>
          </tr>
        </thead>
        <tbody>
          {brokers.map((b) => (
            <tr class="border-t border-dark-100 hover:bg-teal-50/30 transition">
              <td class="px-4 py-3 align-top">
                <a href={b.official_url} rel="noopener noreferrer" target="_blank" class="font-bold text-teal-700 hover:underline">{b.name}</a>
                <p class="text-xs text-dark-500 mt-0.5">{b.platforms}</p>
              </td>
              <td class="px-4 py-3 align-top text-xs text-dark-700 whitespace-nowrap">
                FB {b.rating_fb ?? '—'} / TP {b.rating_tp ?? '—'}
                <br /><span class="text-amber-500" aria-hidden="true">{stars(b.rating_tp)}</span>
              </td>
              <td class="px-4 py-3 align-top text-xs text-dark-700">{b.standard_eurusd}</td>
              <td class="px-4 py-3 align-top text-xs text-dark-700">{b.low_account}</td>
              <td class="px-4 py-3 align-top text-right font-mono text-dark-900 whitespace-nowrap">${b.min_deposit_usd}</td>
              <td class="px-4 py-3 align-top text-right font-mono text-dark-900 whitespace-nowrap">{b.max_leverage}</td>
              <td class="px-4 py-3 align-top text-xs text-dark-700">{b.regulation}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-dark-600">FB = ForexBrokers.com レビュー / TP = Trustpilot TrustScore (★は TP を四捨五入)。— はオフショア中心で同サイト評価対象外。値は 2026 年 5 月時点・変動あり。</p>
  </section>

  <!-- 各社 詳細カード (口コミ + 所見) -->
  <section class="mt-10">
    <h2 class="font-display text-xl font-bold text-dark-900 pb-2 border-b-2 border-teal-700">各社の詳細 — 評価・口コミ・所見</h2>
    <div class="mt-6 grid gap-5 lg:grid-cols-2">
      {brokers.map((b, i) => (
        <article class="reveal card-lift group flex flex-col p-6 border border-dark-200 border-l-4 border-l-teal-700 rounded-xl bg-white hover:border-dark-300" data-reveal-delay={i * 70}>
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-display text-lg font-bold text-dark-900">{b.name}</h3>
              <p class="mt-1 text-xs text-dark-500">{b.regulation}</p>
            </div>
            <div class="text-right text-xs text-dark-600 whitespace-nowrap">
              <span class="text-amber-500" aria-hidden="true">{stars(b.rating_tp)}</span>
              <p class="mt-0.5">TP {b.rating_tp ?? '—'} ({b.tp_reviews})</p>
            </div>
          </div>
          <dl class="mt-4 space-y-1.5 text-xs">
            <div class="flex gap-2"><dt class="w-24 shrink-0 text-dark-500">スタンダード</dt><dd class="text-dark-800">{b.standard_eurusd}</dd></div>
            <div class="flex gap-2"><dt class="w-24 shrink-0 text-dark-500">低スプレッド</dt><dd class="text-dark-800">{b.low_account}</dd></div>
            <div class="flex gap-2"><dt class="w-24 shrink-0 text-dark-500">最小入金 / レバ</dt><dd class="text-dark-800 font-mono">${b.min_deposit_usd} / {b.max_leverage}</dd></div>
            <div class="flex gap-2"><dt class="w-24 shrink-0 text-dark-500">プラットフォーム</dt><dd class="text-dark-800">{b.platforms}</dd></div>
          </dl>
          <div class="mt-4 p-3 rounded-lg bg-dark-50 border border-dark-100">
            <p class="text-xs text-dark-500 font-display font-bold mb-1">海外評価サイトの口コミ傾向</p>
            <p class="text-sm text-dark-700 leading-relaxed">{b.review_voice}</p>
          </div>
          <p class="mt-3 flex-1 text-sm text-dark-700 leading-relaxed"><strong class="text-dark-900">所見:</strong> {b.tcharton_note}</p>
          <a href={b.official_url} rel="noopener noreferrer" target="_blank" class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-teal-700">
            公式サイトで最新条件を確認
            <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- 注意事項 -->
  <section class="mt-10 p-6 border border-dark-200 rounded-xl bg-white text-sm text-dark-700 leading-relaxed">
    <h2 class="font-display font-bold text-base text-dark-900 mb-3">比較の注意点</h2>
    <ul class="space-y-2">
      <li>• スプレッドは<strong class="text-dark-900">変動制</strong>で、相場急変時 (指標発表・early Tokyo 等) には大きく拡大します。表の値は平常時の代表値です。</li>
      <li>• 実質コスト = <strong class="text-dark-900">スプレッド + 往復手数料</strong>。低スプレッド口座は手数料込みで判断してください。</li>
      <li>• 海外 FX 業者は<strong class="text-dark-900">金融庁未登録</strong>です。利用は自己責任で、最新規約・税制 (雑所得 累進課税) をご確認ください。</li>
      <li>• 評価 (ForexBrokers.com / Trustpilot) は<strong class="text-dark-900">第三者サイトの値で変動</strong>します。本ページの順位は紹介料の有無で操作していません。</li>
      <li>• 本ページは投資助言ではなく、ツール (MT5) と組み合わせ可能なブローカーの<strong class="text-dark-900">比較情報</strong>です。</li>
    </ul>
  </section>

  <!-- 関連 -->
  <section class="mt-8 grid gap-4 md:grid-cols-2 text-sm">
    <a href="/docs/" class="reveal card-lift group flex items-start gap-4 p-5 border border-dark-200 border-l-4 border-l-teal-700 rounded-xl bg-white hover:border-dark-300">
      <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-teal-50 text-teal-700" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h7l-1 8 10-12h-7z"/></svg>
      </span>
      <span class="flex-1">
        <h3 class="font-display font-bold text-dark-900 group-hover:text-teal-700">MT5_Python クイックスタート</h3>
        <p class="mt-1.5 text-dark-600 leading-relaxed">どのブローカー口座でも使える MT5 + Python ダッシュボードの導入手順</p>
        <span class="mt-2 inline-flex items-center gap-1.5 font-bold text-teal-700">導入手順を見る<svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </span>
    </a>
    <a href="/legal/disclaimer/" class="reveal card-lift group flex items-start gap-4 p-5 border border-dark-200 border-l-4 border-l-amber-500 rounded-xl bg-white hover:border-dark-300" data-reveal-delay="80">
      <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-amber-50 text-amber-600" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v5c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M12 8v4M12 16h.01"/></svg>
      </span>
      <span class="flex-1">
        <h3 class="font-display font-bold text-dark-900 group-hover:text-teal-700">免責事項</h3>
        <p class="mt-1.5 text-dark-600 leading-relaxed">投資助言業 非該当宣言と損失リスク警告</p>
        <span class="mt-2 inline-flex items-center gap-1.5 font-bold text-teal-700">内容を確認する<svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </span>
    </a>
  </section>
</BaseLayout>

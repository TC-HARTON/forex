---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://tcharton.com/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: 'https://tcharton.com/about/' },
  ],
};

// AboutPage JSON-LD (Person 個人情報を含まない / E-E-A-T は屋号 + 専門領域で代替)
const aboutJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://tcharton.com/about/#about',
  name: 'About — T.C.HARTON',
  description: 'MT5_Python 開発者 / 裁量 FX トレーダー / HARTON 代表のプロフィール',
  about: { '@id': 'https://tcharton.com/#organization' },
  mainEntity: {
    '@type': 'Organization',
    '@id': 'https://tcharton.com/#organization',
    knowsAbout: [
      'MetaTrader 5',
      'Python',
      'MQL5',
      'Forex Trading (Discretionary)',
      'Multi-Timeframe Analysis',
      'Price Action',
      'Currency Strength Index',
      'Economic Calendar Integration',
      'WEB 制作',
      'AI 予測モデル',
    ],
  },
};
const extraJsonLd = `<script type="application/ld+json">${JSON.stringify(breadcrumbJsonLd)}</script><script type="application/ld+json">${JSON.stringify(aboutJsonLd)}</script>`;
---

<BaseLayout
  title="About | T.C.HARTON 代表 | T.C.HARTON"
  description="MT5_Python 開発者、裁量 FX トレーダー、HARTON 代表のプロフィール。WEB 制作と AI 予測モデル開発を本業とし、副業で MT5 + Python OSS を開発。"
  canonicalPath="/about/"
  extraJsonLd={extraJsonLd}
>
  <nav aria-label="パンくず" class="text-xs text-dark-700 mb-6">
    <a href="/" class="hover:text-teal-700">ホーム</a>
    <span aria-hidden="true" class="mx-2">/</span>
    <span aria-current="page">About</span>
  </nav>

  <header class="reveal overflow-hidden rounded-2xl border border-dark-200 bg-white">
    <!-- アクセント帯 (ティールのグラデ) -->
    <div class="h-20 sm:h-24 bg-gradient-to-r from-teal-700 to-teal-500"></div>
    <div class="px-6 pb-6 sm:px-8 sm:pb-8">
      <div class="flex flex-col sm:flex-row sm:items-end gap-5 -mt-12 sm:-mt-14">
        <img
          src="/ceo.webp"
          alt="T.C.HARTON 代表"
          width="128"
          height="128"
          loading="eager"
          decoding="async"
          class="h-28 w-28 sm:h-32 sm:w-32 shrink-0 rounded-full object-cover border-4 border-white shadow-lg bg-dark-100"
        />
        <div class="sm:pb-1">
          <p class="text-xs font-display font-bold tracking-widest uppercase text-teal-700">About</p>
          <h1 class="mt-1 text-2xl sm:text-3xl font-bold tracking-tight text-dark-900">T.C.HARTON 代表</h1>
          <p class="mt-1 text-sm text-dark-600">MT5_Python OSS 開発者 / 裁量 FX トレーダー / WEB・AI エンジニア</p>
        </div>
      </div>
      <p id="summary" class="mt-5 text-sm sm:text-base text-dark-700 leading-relaxed">
        MT5_Python OSS 開発者。HARTON 代表として WEB 制作と AI 予測モデル開発を本業とし、副業で裁量 FX 取引と MT5 + Python ダッシュボードの自作・公開を行っています。
      </p>
    </div>
  </header>

  <section class="mt-10 space-y-6 text-sm leading-relaxed">
    <article>
      <h2 class="font-display font-bold text-lg text-dark-900">運営情報</h2>
      <dl class="mt-3 grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-dark-700">
        <dt class="font-semibold text-dark-900">屋号</dt>
        <dd>T.C.HARTON</dd>
        <dt class="font-semibold text-dark-900">所在地</dt>
        <dd>静岡県沼津市</dd>
        <dt class="font-semibold text-dark-900">本業</dt>
        <dd>WEB 制作 + AI 予測モデル開発 (<a href="https://tcharton.com" class="underline text-teal-700">tcharton.com</a>)</dd>
        <dt class="font-semibold text-dark-900">FX 関連</dt>
        <dd>裁量トレーダー (主戦時間 21:00-25:00 JST / London-NY overlap)</dd>
        <dt class="font-semibold text-dark-900">開発作品</dt>
        <dd>MT5_Python (Python + Dash + MQL5 EA / pytest 134 件 / Phase 5 最適化済)</dd>
        <dt class="font-semibold text-dark-900">連絡先</dt>
        <dd><a href="mailto:info@tcharton.com" class="underline text-teal-700">info@tcharton.com</a></dd>
      </dl>
    </article>

    <article>
      <h2 class="font-display font-bold text-lg text-dark-900">専門領域 (E-E-A-T)</h2>
      <ul class="mt-3 grid sm:grid-cols-2 gap-y-1 text-dark-700">
        <li>• MetaTrader 5 (MT5) 環境構築・カスタマイズ</li>
        <li>• MQL5 EA / インジケータ開発</li>
        <li>• Python + Dash UI による分析エンジン</li>
        <li>• マルチタイムフレーム分析</li>
        <li>• プライスアクション (pin / engulfing 等)</li>
        <li>• 通貨強弱 (Currency Strength Index)</li>
        <li>• 経済指標 (Forex Factory XML) 統合</li>
        <li>• Core Web Vitals / WCAG 2.2 AA / セキュリティ準拠 WEB 制作</li>
      </ul>
    </article>

    <article>
      <h2 class="font-display font-bold text-lg text-dark-900">本サイトの位置付け</h2>
      <p class="mt-3 text-dark-700">
        本サイトは MT5_Python OSS の公式ドキュメントと、裁量 FX 分析手法の教育コンテンツを提供する目的で運営しています。
        投資助言業 (金商法 §29) の登録は受けておらず、売買シグナル・推奨銘柄は配信しません。
      </p>
    </article>

    <article>
      <h2 class="font-display font-bold text-lg text-dark-900">利益相反開示</h2>
      <ul class="mt-3 space-y-2 text-dark-700">
        <li>• MT5_Python は MIT/個人用途で開発しています (Phase 1 時点)。商用版は Phase 3 以降検討。</li>
        <li>• 一部 FX 業者・VPS サービスへのアフィリエイトリンクを掲載する場合があります (該当時はリンク冒頭に明示)。</li>
        <li>• MetaQuotes Software Corp. (MT5 開発元) との資本関係・契約関係はありません。</li>
      </ul>
    </article>
  </section>
</BaseLayout>

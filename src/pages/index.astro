---
import BaseLayout from '../layouts/BaseLayout.astro';
import SessionCountdown from '../components/SessionCountdown.astro';
import EconomicCalendar from '../components/EconomicCalendar.astro';
import CurrencyStrength from '../components/CurrencyStrength.astro';
import blogData from '../data/blog-posts.json';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://tcharton.com/#website',
  url: 'https://tcharton.com/',
  name: 'T.C.HARTON',
  description: 'XAUUSD (ゴールド) 中上級者向け裁量トレードの手法・タイミング発信と、MT5-Python Trading Dashboard。海外 FX ブローカー検証情報。',
  inLanguage: 'ja',
  publisher: { '@id': 'https://tcharton.com/#organization' },
};
const extraJsonLd = `<script type="application/ld+json">${JSON.stringify(websiteJsonLd)}</script>`;

// 最新記事 (blog-posts.json から日付降順に抽出)
const latest = blogData.posts
  .slice()
  .sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0))
  .slice(0, 6);
const catName = blogData._categories;
const catStyle: Record<string, string> = {
  funding:   'bg-amber-100 text-amber-700',
  dashboard: 'bg-teal-50 text-teal-700',
  macro:     'bg-rose-100 text-rose-700',
  method:    'bg-indigo-100 text-indigo-700',
};
const catBorder: Record<string, string> = {
  funding:   'border-l-amber-500',
  dashboard: 'border-l-teal-700',
  macro:     'border-l-rose-500',
  method:    'border-l-indigo-500',
};
const fmtDate = (d: string) => d.replace(/^(\d+)-(\d+)-(\d+)$/, '$1/$2/$3');

// 提供する 3 本柱 (アイコン + アクセント色で メリハリ)
const pillars = [
  { no: '01', accent: 'teal',   icon: 'chart',  title: 'XAUUSD 裁量手法・タイミング発信', body: '中上級者向け。マルチタイムフレーム + 構造ベース (TL/SR・通貨強弱・経済指標) でゴールドの相場コンディションを読む手法を発信します。', cta: '手法を見る', href: '/method/' },
  { no: '02', accent: 'indigo', icon: 'grid',   title: 'MT5-Python Trading Dashboard', body: 'MT5 口座に接続するマルチ通貨テクニカル分析の司令塔。8 銘柄の BIAS・トレンド・通貨強弱・相関・経済指標を一画面で俯瞰します。', cta: 'ダッシュボードを見る', href: '/dashboard/' },
  { no: '03', accent: 'amber',  icon: 'shield', title: '海外 FX ブローカー検証', body: '海外 15 サイト以上の評価データを一次情報で検証。XAUUSD 裁量に必要な約定速度・スプレッド・規制・流動性の観点で比較します。', cta: 'ブローカー検証', href: '/broker/' },
];
const accent: Record<string, { iconBg: string; num: string; bar: string }> = {
  teal:   { iconBg: 'bg-teal-50 text-teal-700',     num: 'text-teal-700',   bar: 'bg-teal-700' },
  indigo: { iconBg: 'bg-indigo-50 text-indigo-600', num: 'text-indigo-600', bar: 'bg-indigo-500' },
  amber:  { iconBg: 'bg-amber-50 text-amber-600',   num: 'text-amber-600',  bar: 'bg-amber-500' },
};

// ダッシュボードの俯瞰機能 (showcase)
const mtsFeatures = [
  '8 銘柄パネル (XAUUSD / 主要ペア)',
  'D1/H4/H1/M15 トレンド・EMA・ADX・RSI',
  'BIAS スコア (10 点満点の方向性)',
  '通貨強弱 (G7+XAU / H1〜W1 切替)',
  '通貨ペア相関 TOP10',
  '経済カレンダー (Forex Factory 連携)',
  'MACRO RATES (実質金利・金利優位)',
  'トレード日誌 (3TF 状況つき自動記録)',
];
---

<BaseLayout
  title="XAUUSD 裁量トレードの分析環境と手法 | MT5-Python Trading Dashboard | T.C.HARTON"
  description="ゴールド (XAUUSD) 中上級者向け裁量トレードの手法・タイミング発信。MT5-Python Trading Dashboard と、海外 15 サイト検証のブローカー情報。今週の経済指標・通貨強弱を毎日更新。"
  keywords="XAUUSD 裁量トレード,ゴールド FX 手法,MT5 ダッシュボード,海外FX 入出金 仮想通貨,通貨強弱,IC Markets,FX 経済指標カレンダー"
  canonicalPath="/"
  ogType="website"
  extraJsonLd={extraJsonLd}
>
  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden pt-10 pb-8 border-b border-dark-100">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <span class="absolute -top-16 right-0 sm:right-10 w-64 h-64 rounded-full bg-teal-200/30 blur-3xl fx-glow"></span>
      <span class="absolute top-24 -left-16 w-72 h-72 rounded-full bg-teal-100/40 blur-3xl fx-float"></span>
    </div>
    <div class="flex flex-wrap items-center justify-between gap-3">
      <p class="inline-flex items-center gap-2 text-xs font-display font-bold tracking-widest uppercase text-teal-700">
        <span class="inline-block w-1.5 h-1.5 bg-teal-700 rounded-full"></span>
        XAUUSD / GOLD 裁量トレード
      </p>
      <SessionCountdown />
    </div>

    <h1 class="hero-rise d1 mt-6 font-display text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-dark-900 leading-[1.15]">
      ゴールドの相場を、<br class="hidden sm:block" />
      <span class="gradient-text">構造</span>で読む。
    </h1>
    <p id="summary" class="hero-rise d2 mt-5 max-w-2xl text-base sm:text-lg text-dark-700 leading-relaxed">
      XAUUSD (ゴールド) 中上級者向けの裁量トレード手法・タイミング発信。
      マルチタイムフレーム分析ツール <strong class="text-dark-900">MT5-Python Trading Dashboard</strong> と、
      海外 15 サイト検証のブローカー情報を提供します。
    </p>

    <div class="hero-rise d3 mt-7 flex flex-wrap gap-3">
      <a href="/method/" class="btn-pop group inline-flex items-center gap-2 px-6 py-3 bg-teal-700 text-white rounded-md font-bold text-sm hover:bg-teal-800">
        裁量手法を見る
        <svg class="arrow-go" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <a href="/dashboard/" class="btn-pop inline-flex items-center gap-2 px-6 py-3 border border-dark-300 rounded-md text-dark-800 font-medium text-sm hover:border-teal-700 hover:text-teal-700">
        分析ダッシュボードを見る
      </a>
    </div>

  </section>

  <!-- ===== 最新記事 ===== -->
  <section aria-label="最新記事" class="py-14 border-b border-dark-100">
    <div class="flex items-end justify-between flex-wrap gap-2">
      <div>
        <p class="text-xs font-display font-bold tracking-widest uppercase text-teal-700">Latest</p>
        <h2 class="mt-2 font-display text-2xl font-bold text-dark-900">最新記事</h2>
      </div>
      <a href="/blog/" class="group inline-flex items-center gap-1.5 text-sm font-bold text-teal-700">
        記事一覧をすべて見る
        <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((p, i) => (
        <a href={`/blog/${p.slug}/`} class={`group reveal card-lift relative flex flex-col rounded-xl border border-dark-200 border-l-4 ${catBorder[p.category]} bg-white p-5 hover:border-dark-300`} data-reveal-delay={i * 90}>
          <div class="flex items-center gap-2 text-xs">
            <span class={`px-2 py-0.5 rounded font-display font-bold ${catStyle[p.category]}`}>{catName[p.category as keyof typeof catName]}</span>
            <time datetime={p.date} class="text-dark-500">{fmtDate(p.date)}</time>
            <span class="text-dark-400" aria-hidden="true">·</span>
            <span class="text-dark-500">約 {p.readingMin} 分</span>
          </div>
          <h3 class="mt-3 font-display font-bold text-dark-900 leading-snug group-hover:text-teal-700">{p.title}</h3>
          <p class="mt-2 flex-1 text-sm text-dark-600 leading-relaxed line-clamp-2">{p.excerpt}</p>
          <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-teal-700">
            続きを読む
            <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== 提供する 3 本柱 ===== -->
  <section aria-label="提供内容" class="py-14">
    <h2 class="font-display text-2xl font-bold text-dark-900 text-center">このサイトが提供するもの</h2>
    <p class="mt-3 text-sm text-dark-700 text-center max-w-xl mx-auto">
      裁量トレーダーの「相場を読む環境」と「ゴールドの手法」、そして口座選びまでを一貫して支援します。
    </p>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {pillars.map((p, i) => {
        const a = accent[p.accent];
        return (
        <article class="group reveal card-lift relative overflow-hidden flex flex-col p-6 border border-dark-200 rounded-xl bg-white hover:border-teal-700" data-reveal-delay={i * 120}>
          <span class={`absolute inset-x-0 top-0 h-1 ${a.bar} opacity-70 transition-all group-hover:h-1.5 group-hover:opacity-100`} aria-hidden="true"></span>
          <div class="flex items-center justify-between">
            <span class={`inline-flex h-11 w-11 items-center justify-center rounded-lg ${a.iconBg}`}>
              {p.icon === 'chart' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><path d="M7 14l3-3 3 3 5-6"/></svg>
              )}
              {p.icon === 'grid' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="5" rx="1"/><rect x="13" y="10" width="8" height="11" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/></svg>
              )}
              {p.icon === 'shield' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l8 3v5c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
              )}
            </span>
            <span class={`font-mono text-3xl font-extrabold ${a.num} opacity-20`}>{p.no}</span>
          </div>
          <h3 class="mt-4 font-display text-lg font-bold text-dark-900">{p.title}</h3>
          <p class="mt-3 flex-1 text-sm text-dark-700 leading-relaxed">{p.body}</p>
          <a href={p.href} class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-teal-700">
            {p.cta}
            <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </article>
        );
      })}
    </div>
  </section>

  <!-- ===== ダッシュボード ショーケース (差別化の核) ===== -->
  <section aria-label="MT5-Python Trading Dashboard" class="reveal py-14 border-y border-dark-100">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <p class="text-xs font-display font-bold tracking-widest uppercase text-teal-700">The Analysis Engine</p>
        <h2 class="mt-3 font-display text-2xl sm:text-3xl font-bold text-dark-900 leading-tight">
          裁量の根拠を体系化する<br />MT5-Python Trading Dashboard
        </h2>
        <p class="mt-4 text-sm text-dark-700 leading-relaxed">
          シグナルツールではなく、相場のコンディションを一目で俯瞰する「司令塔」。
          8 銘柄のマルチタイムフレーム分析・通貨強弱・相関・経済指標を 1 画面に統合し、
          裁量判断に必要な情報を欠落なく提示します。
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/dashboard/" class="btn-pop inline-block px-5 py-2.5 bg-teal-700 text-white rounded-md font-bold text-sm hover:bg-teal-800">
            ダッシュボードの詳細 →
          </a>
          <a href="/live/" class="btn-pop inline-block px-5 py-2.5 border border-dark-300 rounded-md text-dark-800 font-medium text-sm hover:border-teal-700 hover:text-teal-700">
            ライブ表示 (準備中)
          </a>
        </div>
      </div>

      <!-- 機能グリッド (スクショ準備までの代替 / データ密度演出) -->
      <div class="border border-dark-200 rounded-xl bg-white overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-dark-200 bg-dark-50">
          <span class="w-2.5 h-2.5 rounded-full bg-red-300"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-amber-300"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-teal-400"></span>
          <span class="ml-2 font-mono text-xs text-dark-500">MT5-Python Trading Dashboard</span>
        </div>
        <ul class="grid sm:grid-cols-2 gap-px bg-dark-100">
          {mtsFeatures.map((f) => (
            <li class="bg-white px-4 py-3 text-xs text-dark-700 flex items-start gap-2">
              <span class="text-teal-700 mt-0.5" aria-hidden="true">▸</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== ライブデータ (鮮度 = FX サイトの価値) ===== -->
  <section aria-label="マーケットデータ" class="reveal py-14">
    <div class="flex items-baseline justify-between gap-3 flex-wrap">
      <h2 class="font-display text-2xl font-bold text-dark-900">いまの相場コンディション</h2>
      <p class="text-xs text-dark-600">毎日自動更新 / 出典明記 / 参考情報</p>
    </div>
    <CurrencyStrength />
    <EconomicCalendar />
  </section>

  <!-- ===== IC Markets (収益導線 / ソフト) ===== -->
  <section aria-label="推奨ブローカー" class="reveal py-14 border-y border-dark-100">
    <div class="card-lift p-6 sm:p-8 border-2 border-teal-700 rounded-xl bg-teal-50/40">
      <div class="flex flex-wrap items-center gap-3">
        <span class="text-xs px-2 py-0.5 bg-teal-700 text-white rounded font-display font-bold">検証済み推奨</span>
        <h2 class="font-display text-xl sm:text-2xl font-bold text-dark-900">IC Markets — XAUUSD 裁量に最適な理由</h2>
      </div>
      <p class="mt-3 text-sm text-dark-700 leading-relaxed max-w-3xl">
        ForexBrokers.com 4.5/5・Trustpilot 4.8/5 (レビュー 5 万件超) 等、海外 15 サイト以上の一次情報で検証。
        約定 40ms 未満・Raw Spread 0.1pips・ASIC/CySEC の Tier-1 規制 2 つ・日次 813 億ドルの流動性。
        <strong class="text-dark-900">なぜ最適かを出典付きで解説</strong>しています。
      </p>
      <a href="/broker/icmarkets/" class="btn-pop mt-5 inline-block px-5 py-2.5 bg-teal-700 text-white rounded-md font-bold text-sm hover:bg-teal-800">
        検証記事を読む →
      </a>
      <p class="mt-3 text-xs text-dark-600">※ アフィリエイト (IB) リンクを含みます。評価・順位は報酬の有無で操作していません。</p>
    </div>
  </section>

  <!-- ===== 法的明示 ===== -->
  <section class="mt-10 p-6 border border-dark-200 rounded-xl text-xs sm:text-sm text-dark-700 leading-relaxed">
    <p class="font-display font-bold text-dark-900 mb-2">本サイトの位置付け</p>
    <p>
      本サイトおよび MT5-Python Trading Dashboard は、裁量トレーダー向けの<strong class="text-dark-900">手法解説・ツール紹介・教育目的</strong>で運営しています。
      投資助言業 (金商法 §29) の登録は受けておらず、<strong class="text-dark-900">特定の売買シグナル配信・推奨銘柄の断定</strong>は行いません。
      表示される全ての情報は参考情報であり、FX 取引は元本を超える損失が生じる可能性があります。最終判断と結果は閲覧者ご自身の自己責任となります。
      詳細は <a href="/legal/disclaimer/" class="underline text-teal-700">免責事項</a> を参照してください。
    </p>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import posts from '../../data/method-posts.json';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://tcharton.com/' },
    { '@type': 'ListItem', position: 2, name: 'Method', item: 'https://tcharton.com/method/' },
  ],
};
const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'XAUUSD 裁量トレード手法',
  itemListElement: posts.posts
    .slice()
    .sort((a, b) => a.order - b.order)
    .map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: p.title,
      url: `https://tcharton.com/method/${p.slug}/`,
    })),
};
const extraJsonLd = `<script type="application/ld+json">${JSON.stringify(breadcrumbJsonLd)}</script><script type="application/ld+json">${JSON.stringify(itemListJsonLd)}</script>`;

const sorted = posts.posts.slice().sort((a, b) => a.order - b.order);

// STEP 別アクセント (カード左ボーダー・番号チップ・上端バー)
const stepTheme: Record<number, { border: string; chip: string; bar: string }> = {
  1: { border: 'border-l-teal-700',   chip: 'bg-teal-50 text-teal-700',     bar: 'bg-teal-700' },
  2: { border: 'border-l-indigo-500', chip: 'bg-indigo-50 text-indigo-600', bar: 'bg-indigo-500' },
  3: { border: 'border-l-rose-500',   chip: 'bg-rose-100 text-rose-700',    bar: 'bg-rose-500' },
  4: { border: 'border-l-amber-500',  chip: 'bg-amber-50 text-amber-600',   bar: 'bg-amber-500' },
};
const stepFallback = { border: 'border-l-teal-700', chip: 'bg-teal-50 text-teal-700', bar: 'bg-teal-700' };
---

<BaseLayout
  title="XAUUSD 裁量トレード手法 | 中上級者向け 4 ステップ | T.C.HARTON"
  description="ゴールド (XAUUSD) 中上級者向け裁量トレード手法を 4 記事で体系解説。マルチタイムフレーム分析・構造ベース (TL/SR)・通貨強弱でのペア選択・経済指標との向き合い方を図解付きで。教育目的。"
  keywords="XAUUSD 裁量トレード 手法,ゴールド トレード やり方,マルチタイムフレーム,構造ベース 手法,通貨強弱 ペア選び,FX 環境認識"
  canonicalPath="/method/"
  ogImage="/og/default.png"
  extraJsonLd={extraJsonLd}
>
  <nav aria-label="パンくず" class="text-xs text-dark-600 mb-6">
    <a href="/" class="hover:text-teal-700">ホーム</a>
    <span aria-hidden="true" class="mx-2">/</span>
    <span aria-current="page">Method</span>
  </nav>

  <header>
    <p class="text-xs font-display font-bold tracking-widest uppercase text-teal-700">Trading Method</p>
    <h1 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-dark-900">XAUUSD 裁量トレード手法</h1>
    <p id="summary" class="mt-4 text-dark-700 leading-relaxed max-w-2xl">
      ゴールド (XAUUSD) を主戦場とする中上級者向けの裁量手法を、4 つのステップで体系的に解説します。
      上位足で「方向」を決め、構造で「場所」を絞り、通貨強弱で「ペア」を選び、経済指標で「タイミングの危険」を避ける。
      これが一貫した裁量トレードの骨格です (教育目的)。
    </p>
  </header>

  <!-- 4 ステップ フロー図 -->
  <section aria-label="手法の全体像" class="mt-8 p-6 border border-dark-200 rounded-xl bg-white">
    <h2 class="font-display font-bold text-lg text-dark-900">手法の全体像 — 4 つの問い</h2>
    <div class="mt-5 grid sm:grid-cols-4 gap-3">
      <div class="reveal p-4 rounded-lg bg-teal-50 border border-teal-200 border-t-4 border-t-teal-700" data-reveal-delay="0">
        <p class="font-mono text-xs font-bold text-teal-700">STEP 1</p>
        <p class="mt-1 font-display font-bold text-sm text-dark-900">どっち向き?</p>
        <p class="mt-1 text-xs text-dark-700">マルチタイムフレームで方向を決める</p>
      </div>
      <div class="reveal p-4 rounded-lg bg-indigo-50 border border-indigo-200 border-t-4 border-t-indigo-500" data-reveal-delay="80">
        <p class="font-mono text-xs font-bold text-indigo-600">STEP 2</p>
        <p class="mt-1 font-display font-bold text-sm text-dark-900">どこで?</p>
        <p class="mt-1 text-xs text-dark-700">構造レベルで場所を絞る</p>
      </div>
      <div class="reveal p-4 rounded-lg bg-rose-50 border border-rose-200 border-t-4 border-t-rose-500" data-reveal-delay="160">
        <p class="font-mono text-xs font-bold text-rose-600">STEP 3</p>
        <p class="mt-1 font-display font-bold text-sm text-dark-900">何を?</p>
        <p class="mt-1 text-xs text-dark-700">通貨強弱でペアを選ぶ</p>
      </div>
      <div class="reveal p-4 rounded-lg bg-amber-50 border border-amber-200 border-t-4 border-t-amber-500" data-reveal-delay="240">
        <p class="font-mono text-xs font-bold text-amber-700">STEP 4</p>
        <p class="mt-1 font-display font-bold text-sm text-dark-900">いつ避ける?</p>
        <p class="mt-1 text-xs text-dark-700">経済指標の危険時間を外す</p>
      </div>
    </div>
  </section>

  <!-- 記事カード一覧 -->
  <section aria-label="手法記事一覧" class="mt-8 grid gap-5 sm:grid-cols-2">
    {sorted.map((p) => {
      const t = stepTheme[p.order] ?? stepFallback;
      return (
      <a href={`/method/${p.slug}/`} class={`reveal card-lift group relative overflow-hidden flex flex-col p-6 border border-dark-200 border-l-4 ${t.border} rounded-xl bg-white hover:border-dark-300`} data-reveal-delay={p.order * 100}>
        <span class={`absolute inset-x-0 top-0 h-1 ${t.bar} opacity-60 transition-all group-hover:h-1.5 group-hover:opacity-100`} aria-hidden="true"></span>
        <div class="flex items-center gap-2 text-xs">
          <span class={`px-2 py-0.5 rounded font-mono font-bold ${t.chip}`}>STEP {p.order}</span>
          <span class="text-dark-500">約 {p.readingMin} 分</span>
        </div>
        <h2 class="mt-2.5 font-display text-lg font-bold text-dark-900 group-hover:text-teal-700">{p.title}</h2>
        <p class="mt-3 flex-1 text-sm text-dark-700 leading-relaxed">{p.excerpt}</p>
        <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-teal-700">
          記事を読む
          <svg class="arrow-go" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
      );
    })}
  </section>

  <section class="mt-10 p-6 border-l-4 border-teal-700 bg-teal-50 rounded-r text-sm text-dark-700 leading-relaxed">
    本ページの手法解説は<strong class="text-dark-900">教育目的</strong>であり、特定の売買タイミングを断定・推奨するものではありません。
    投資助言業 (金商法 §29) には該当しません。詳細は <a href="/legal/disclaimer/" class="underline text-teal-700">免責事項</a> を参照してください。
  </section>
</BaseLayout>

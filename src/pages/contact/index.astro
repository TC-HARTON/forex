---
import BaseLayout from '../../layouts/BaseLayout.astro';

/**
 * Web3Forms アクセスキー。
 * 既定は本サイト (tcharton.com) と共用のキー (送信先 info@tcharton.com / 公開前提の値)。
 * fx 専用キーを取得した場合はこの 1 行を差し替えるだけでよい。無料枠 月 250 送信。
 */
const WEB3FORMS_ACCESS_KEY = '9fda1d98-e246-4730-a12c-2251a5ae35b0';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://tcharton.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://tcharton.com/contact/' },
  ],
};
const contactJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': 'https://tcharton.com/contact/#contact',
  name: 'お問い合わせ — T.C.HARTON',
  mainEntity: {
    '@type': 'Organization',
    '@id': 'https://tcharton.com/#organization',
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      email: 'info@tcharton.com',
      availableLanguage: ['ja'],
    },
  },
};
const extraJsonLd = `<script type="application/ld+json">${JSON.stringify(breadcrumbJsonLd)}</script><script type="application/ld+json">${JSON.stringify(contactJsonLd)}</script>`;

const topics = [
  'MT5-Python Trading Dashboard について',
  '裁量手法・記事の内容について',
  'ブローカー・入出金について',
  'WEB 制作 / AI 開発の相談',
  'その他',
];
const fallbackMail = 'mailto:info@tcharton.com?subject=' + encodeURIComponent('【お問い合わせ】T.C.HARTON');
---

<BaseLayout
  title="お問い合わせ | T.C.HARTON"
  description="T.C.HARTON へのお問い合わせ。MT5-Python Trading Dashboard・裁量手法・ブローカー・WEB/AI 開発のご相談はこちらから。"
  canonicalPath="/contact/"
  extraJsonLd={extraJsonLd}
>
  <nav aria-label="パンくず" class="text-xs text-dark-700 mb-6">
    <a href="/" class="hover:text-teal-700">ホーム</a>
    <span aria-hidden="true" class="mx-2">/</span>
    <span aria-current="page">Contact</span>
  </nav>

  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <span class="absolute -top-12 -right-8 w-56 h-56 rounded-full bg-teal-200/40 blur-3xl fx-glow"></span>
      <span class="absolute top-40 -left-12 w-64 h-64 rounded-full bg-teal-100/50 blur-3xl fx-float"></span>
    </div>

    <header class="max-w-2xl">
      <p class="fade-up text-xs font-display font-bold tracking-widest uppercase text-teal-700">Contact</p>
      <h1 class="fade-up d1 mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-dark-900">お問い合わせ</h1>
      <p class="fade-up d2 mt-4 text-dark-700 leading-relaxed">
        ダッシュボード・裁量手法・ブローカー、または WEB 制作 / AI 開発のご相談まで。
        以下のフォームからお気軽にどうぞ。送信後は確認ページを表示します。
      </p>
    </header>

    <div class="mt-10 grid gap-8 lg:grid-cols-5">
      <!-- 左: 連絡先 -->
      <aside class="lg:col-span-2 space-y-4">
        <div class="reveal card-lift p-6 rounded-xl border border-dark-200 border-l-4 border-l-teal-700 bg-white">
          <div class="flex items-center gap-3">
            <span class="relative inline-flex h-11 w-11 items-center justify-center rounded-lg bg-teal-50 text-teal-700">
              <span class="absolute inset-0 rounded-lg bg-teal-400/30 fx-pulse-ring" aria-hidden="true"></span>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            </span>
            <div>
              <p class="text-xs text-dark-500">メール</p>
              <a href={fallbackMail} class="font-display font-bold text-dark-900 hover:text-teal-700">info@tcharton.com</a>
            </div>
          </div>
          <p class="mt-4 text-sm text-dark-600 leading-relaxed">通常 2〜3 営業日以内に返信します。お急ぎの場合は件名に「至急」とご記載ください。</p>
        </div>

        <div class="reveal card-lift p-6 rounded-xl border border-dark-200 border-l-4 border-l-amber-500 bg-white" data-reveal-delay="80">
          <h2 class="font-display font-bold text-dark-900">お問い合わせ前に</h2>
          <ul class="mt-3 space-y-2 text-sm text-dark-700">
            <li>・投資助言・売買シグナルの提供は行っていません (<a href="/legal/disclaimer/" class="underline text-teal-700">免責事項</a>)。</li>
            <li>・ダッシュボードの使い方は <a href="/dashboard/" class="underline text-teal-700">Dashboard</a> / <a href="/blog/" class="underline text-teal-700">Blog</a> もご覧ください。</li>
            <li>・個人情報の取り扱いは <a href="/legal/privacy/" class="underline text-teal-700">プライバシーポリシー</a> に準じます。</li>
          </ul>
        </div>
      </aside>

      <!-- 右: フォーム (Web3Forms 実送信 → /contact/thanks/) -->
      <div class="lg:col-span-3">
        <form action="https://api.web3forms.com/submit" method="POST"
          class="reveal p-6 sm:p-8 rounded-xl border border-dark-200 bg-white space-y-5">
          <!-- Web3Forms 設定 -->
          <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
          <input type="hidden" name="subject" value="【お問い合わせ】tcharton.com" />
          <input type="hidden" name="from_name" value="tcharton.com お問い合わせフォーム" />
          <input type="hidden" name="redirect" value="https://tcharton.com/contact/thanks/" />
          <!-- スパム対策ハニーポット (人間は入力しない) -->
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-semibold text-dark-900">お名前 <span class="text-rose-600">*</span></label>
              <input type="text" id="name" name="name" required autocomplete="name" placeholder="山田 太郎"
                class="mt-1.5 w-full px-4 py-3 rounded-lg border border-dark-200 text-base focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 outline-none transition" />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-dark-900">メールアドレス <span class="text-rose-600">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@example.com"
                class="mt-1.5 w-full px-4 py-3 rounded-lg border border-dark-200 text-base focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 outline-none transition" />
            </div>
            <div>
              <label for="company" class="block text-sm font-semibold text-dark-900">会社名・屋号 <span class="text-dark-400 font-normal">(任意)</span></label>
              <input type="text" id="company" name="company" autocomplete="organization"
                class="mt-1.5 w-full px-4 py-3 rounded-lg border border-dark-200 text-base focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 outline-none transition" />
            </div>
            <div>
              <label for="tel" class="block text-sm font-semibold text-dark-900">電話番号 <span class="text-dark-400 font-normal">(任意)</span></label>
              <input type="tel" id="tel" name="tel" autocomplete="tel"
                class="mt-1.5 w-full px-4 py-3 rounded-lg border border-dark-200 text-base focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 outline-none transition" />
            </div>
          </div>

          <div>
            <label for="topic" class="block text-sm font-semibold text-dark-900">お問い合わせ種別</label>
            <select id="topic" name="topic"
              class="mt-1.5 w-full px-4 py-3 rounded-lg border border-dark-200 text-base bg-white focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 outline-none transition">
              <option value="">選択してください</option>
              {topics.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-dark-900">お問い合わせ内容 <span class="text-rose-600">*</span></label>
            <textarea id="message" name="message" rows="6" required placeholder="お問い合わせ内容をご記入ください"
              class="mt-1.5 w-full px-4 py-3 rounded-lg border border-dark-200 text-base focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 outline-none transition resize-y"></textarea>
          </div>

          <div class="flex items-start gap-2 text-xs text-dark-600">
            <input type="checkbox" id="agree" name="プライバシー同意" required value="同意する" class="mt-0.5 h-4 w-4 rounded border-dark-300 text-teal-700 focus:ring-teal-500" />
            <label for="agree"><a href="/legal/privacy/" class="underline text-teal-700">プライバシーポリシー</a>に同意のうえ送信します <span class="text-rose-600">*</span></label>
          </div>

          <button type="submit"
            class="btn-pop group inline-flex items-center justify-center gap-2 w-full sm:w-auto px-7 py-3.5 rounded-lg bg-teal-700 text-white font-bold text-sm hover:bg-teal-800">
            この内容で送信する
            <svg class="arrow-go" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>

          <p class="text-xs text-dark-500 leading-relaxed border-t border-dark-100 pt-4">
            ※ 送信内容は Web3Forms 経由で運営者宛メールに届きます。送信後は確認ページを表示します。
            うまく送信できない場合は <a href={fallbackMail} class="underline text-teal-700">直接メールする</a> か info@tcharton.com 宛にご連絡ください。
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

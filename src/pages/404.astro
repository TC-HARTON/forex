---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  { href: '/method/', label: '裁量手法' },
  { href: '/dashboard/', label: 'ダッシュボード' },
  { href: '/broker/', label: 'ブローカー比較' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: '運営者情報' },
  { href: '/contact/', label: 'お問い合わせ' },
];
---

<BaseLayout
  title="404 | ページが見つかりません | T.C.HARTON"
  description="お探しのページは見つかりませんでした。URL の変更・削除・公開準備中の可能性があります。トップページや裁量手法・ダッシュボード・ブローカー比較・ブログから目的のページをお探しください。"
  canonicalPath="/404/"
  robots="noindex,follow"
>
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <span class="absolute -top-10 right-4 sm:right-20 w-48 h-48 rounded-full bg-teal-200/40 blur-3xl fx-glow"></span>
      <span class="absolute top-32 -left-10 w-56 h-56 rounded-full bg-teal-100/50 blur-3xl fx-float"></span>
    </div>

    <div class="text-center max-w-2xl mx-auto py-16 sm:py-24">
      <p class="fx-bob text-[88px] sm:text-[150px] leading-none font-display font-extrabold gradient-text select-none">404</p>
      <h1 class="fade-up d1 mt-2 text-2xl sm:text-3xl font-display font-bold text-dark-900">お探しのページは見つかりませんでした</h1>
      <p class="fade-up d2 mt-4 text-dark-600 leading-relaxed">
        URL が変更されたか、削除された可能性があります。<br class="hidden sm:block" />
        以下のリンクから目的のページをお探しください。
      </p>

      <div class="fade-up d2 mt-9 flex flex-wrap gap-3 justify-center">
        <a href="/" class="btn-pop inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-teal-700 text-white font-bold text-sm hover:bg-teal-800">
          トップページへ
          <svg class="arrow-go" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/blog/" class="btn-pop inline-flex items-center px-6 py-3 rounded-lg border border-dark-300 text-dark-800 font-medium text-sm hover:border-teal-700 hover:text-teal-700">
          記事を読む
        </a>
      </div>

      <div class="fade-up d3 mt-14 grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
        {links.map((l) => (
          <a href={l.href} class="card-lift py-3 px-2 rounded-lg bg-dark-50 border border-dark-100 text-dark-700 hover:bg-teal-50 hover:border-teal-200 hover:text-teal-700 transition-colors">{l.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

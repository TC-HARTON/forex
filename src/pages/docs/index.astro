---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://tcharton.com/' },
    { '@type': 'ListItem', position: 2, name: 'Docs', item: 'https://tcharton.com/docs/' },
  ],
};
const extraJsonLd = `<script type="application/ld+json">${JSON.stringify(breadcrumbJsonLd)}</script>`;
---

<BaseLayout
  title="Docs | MT5_Python ドキュメント | T.C.HARTON"
  description="MT5_Python (Python + Dash + MQL5 EA ローカル統合ダッシュボード) のインストール・クイックスタート・アーキテクチャ・SPEC ドキュメント hub。"
  canonicalPath="/docs/"
  extraJsonLd={extraJsonLd}
>
  <nav aria-label="パンくず" class="text-xs text-dark-700 mb-6">
    <a href="/" class="hover:text-teal-700">ホーム</a>
    <span aria-hidden="true" class="mx-2">/</span>
    <span aria-current="page">Docs</span>
  </nav>

  <header>
    <p class="text-xs font-display font-bold tracking-widest uppercase text-teal-700">Documentation</p>
    <h1 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight">MT5_Python ドキュメント</h1>
    <p id="summary" class="mt-4 text-dark-700 leading-relaxed">
      完全裁量・マルチタイムフレーム前提のローカル統合ダッシュボード。インストールから運用までのドキュメント hub。
    </p>
  </header>

  <section class="mt-10 grid gap-4 md:grid-cols-2 text-sm">
    <article class="p-6 border border-dark-200 rounded bg-dark-50">
      <h2 class="font-semibold">Install</h2>
      <p class="mt-2 text-dark-700">Python / MT5 / MQL5 EA 環境構築 (Phase 1 Week 3-4 公開予定)</p>
    </article>
    <article class="p-6 border border-dark-200 rounded bg-dark-50">
      <h2 class="font-semibold">Quickstart</h2>
      <p class="mt-2 text-dark-700">5 分で起動・ブラウザ表示まで (Phase 1 Week 3-4 公開予定)</p>
    </article>
    <article class="p-6 border border-dark-200 rounded bg-dark-50">
      <h2 class="font-semibold">Dashboard Guide</h2>
      <p class="mt-2 text-dark-700">銘柄パネル / 通貨強弱 / 相関ヒートマップ 使い方 (Phase 1 Week 3-4)</p>
    </article>
    <article class="p-6 border border-dark-200 rounded bg-dark-50">
      <h2 class="font-semibold">Architecture</h2>
      <p class="mt-2 text-dark-700">MT5 ↔ Python ↔ Browser 通信設計 (Phase 1 Week 3-4)</p>
    </article>
    <article class="p-6 border border-dark-200 rounded bg-dark-50 md:col-span-2">
      <h2 class="font-semibold">SPEC</h2>
      <p class="mt-2 text-dark-700">作品本体 SPEC 公開 (改変禁止 / 参照のみ) — Phase 1 Week 3-4</p>
    </article>
  </section>

  <p class="mt-10 text-xs text-dark-700 text-center">
    現在 Phase 1 Week 1-2 完了。Week 3-4 で各サブページ本実装予定。
  </p>
</BaseLayout>

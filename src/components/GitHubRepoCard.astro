---
/**
 * GitHubRepoCard.astro — GitHub リポジトリ統計カード
 *
 * Pattern: TradingView の social proof / Investing の data 表示
 * Source: src/data/github-repo.json (Phase 1 placeholder)
 * Phase 1.6: GitHub API 週次 fetch スクリプト
 */
import data from '../data/github-repo.json';
const r = data.repo;
const m = data.mt5_python_repo;
---

<section aria-label="GitHub リポジトリ" class="mt-10 border border-dark-200 rounded bg-white">
  <header class="px-5 py-4 border-b border-dark-200 bg-dark-50">
    <h2 class="font-display font-bold text-lg text-dark-900">GitHub オープンソース</h2>
    <p class="mt-1 text-xs text-dark-700">本サイトおよび MT5_Python は全コード公開予定 (週次更新)</p>
  </header>
  <div class="grid sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-dark-200">
    <!-- tcharton.com 本体 -->
    <article class="p-5">
      <a href={r.url} rel="noopener noreferrer" target="_blank" class="block hover:bg-teal-50/30 -m-5 p-5 transition rounded">
        <div class="flex items-center justify-between gap-2">
          <h3 class="font-mono font-bold text-sm text-teal-700">{r.name}</h3>
          <span class="text-xs text-dark-700">{r.language_primary}</span>
        </div>
        <p class="mt-2 text-sm text-dark-700 leading-relaxed">{r.description}</p>
        <dl class="mt-3 grid grid-cols-3 gap-2 text-xs text-dark-700">
          <div><dt class="text-dark-500">★ Stars</dt><dd class="font-mono font-bold text-dark-900">{r.stars}</dd></div>
          <div><dt class="text-dark-500">⑂ Forks</dt><dd class="font-mono font-bold text-dark-900">{r.forks}</dd></div>
          <div><dt class="text-dark-500">! Issues</dt><dd class="font-mono font-bold text-dark-900">{r.issues_open}</dd></div>
        </dl>
        <p class="mt-3 text-xs text-teal-700">GitHub で見る →</p>
      </a>
    </article>
    <!-- MT5_Python 本体 -->
    <article class="p-5">
      <div class="flex items-center justify-between gap-2">
        <h3 class="font-mono font-bold text-sm text-dark-900">{m.name}</h3>
        <span class="text-xs px-2 py-0.5 bg-amber-50 text-amber-700 border border-amber-200 rounded">Private (Phase 1)</span>
      </div>
      <p class="mt-2 text-sm text-dark-700 leading-relaxed">{m.description}</p>
      <dl class="mt-3 grid grid-cols-2 gap-2 text-xs text-dark-700">
        <div><dt class="text-dark-500">pytest</dt><dd class="font-mono font-bold text-dark-900">{m.tests} 件</dd></div>
        <div><dt class="text-dark-500">Phase</dt><dd class="font-mono font-bold text-dark-900">{m.phase}</dd></div>
      </dl>
      <p class="mt-3 text-xs text-dark-500">{m._status}</p>
    </article>
  </div>
</section>

---
/**
 * CurrencyStrength.astro — 通貨強弱インデックス (G8 法定通貨 / 中央 0 基準)
 *
 * データソース: src/data/currency-strength.json
 *  - 生成: scripts/fetch-currency-strength.mjs (ECB 公式データ / Frankfurter API)
 *  - 更新: GitHub Actions daily-data-refresh.yml で毎日自動 (MT5 不要・完全自動)
 *
 * 表示: 中央 0 を基準に
 *  - 右 (正 / teal): 強い = 買い傾向
 *  - 左 (負 / red):  弱い = 売り傾向
 *  → 強い通貨を買い・弱い通貨を売る「通貨ペア」発想のヒントになる。
 */
import data from '../data/currency-strength.json';

// bias (符号付き -50..+50) で降順。旧 JSON 互換: bias 無ければ score-50。
const rows = data.currencies
  .map((c) => ({ ...c, bias: c.bias ?? ((c.score ?? 50) - 50) }))
  .sort((a, b) => b.bias - a.bias);

// バー半幅 (%): |bias| / 50 → 0..100 (片側 50% 枠に対する充填率)
function pct(bias) {
  return Math.min(100, Math.round((Math.abs(bias) / 50) * 100));
}

// 鮮度判定 (ECB 営業日終値ベース)
const fetchedAt = data._fetched_at ? new Date(data._fetched_at) : null;
const ageHr = fetchedAt ? (Date.now() - fetchedAt.getTime()) / 3600000 : Infinity;
let staleLevel = 'fresh';
if (ageHr > 5 * 24) staleLevel = 'stale';
else if (ageHr > 48) staleLevel = 'warn';

const fetchedJst = fetchedAt
  ? new Date(fetchedAt.getTime() + 9 * 3600 * 1000).toISOString().slice(0, 16).replace('T', ' ')
  : '—';

const staleClass = {
  fresh: 'text-dark-600',
  warn:  'text-amber-700 font-bold',
  stale: 'text-red-700 font-bold',
}[staleLevel];

const staleLabel = {
  fresh: '',
  warn:  ' (48 時間以上前)',
  stale: ' ⚠ 自動更新が停止している可能性',
}[staleLevel];
---

<section aria-label="通貨強弱インデックス" class="mt-10 border border-dark-200 rounded-xl bg-white overflow-hidden">
  <header class="flex flex-wrap items-baseline justify-between gap-2 px-5 py-4 border-b border-dark-200 bg-dark-50">
    <h2 class="font-display font-bold text-lg text-dark-900">通貨強弱 (G8 法定通貨)</h2>
    <p class="text-xs">
      <span class="text-dark-600">{data._period || ''} / 中央 0 基準 / 出典: ECB (Frankfurter API) / </span>
      <span class={staleClass}>取得 <span class="font-mono">{fetchedJst} JST</span>{staleLabel}</span>
    </p>
  </header>

  {staleLevel === 'stale' && (
    <div role="alert" class="mx-5 mt-4 p-3 border border-red-300 bg-red-50 rounded text-xs text-red-800 leading-relaxed">
      ⚠ <strong>本データは 5 営業日以上更新されていません</strong>。自動更新ワークフローが停止している可能性があります。
      <a href="/legal/disclaimer/" class="underline">免責事項</a>を確認の上、参考値として扱ってください。
    </div>
  )}

  <!-- 凡例 -->
  <div class="flex items-center justify-between px-5 pt-4 text-xs text-dark-600">
    <span class="inline-flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-red-400"></span>← 弱い (売り傾向)</span>
    <span class="font-mono text-dark-400">0</span>
    <span class="inline-flex items-center gap-1.5">強い (買い傾向) →<span class="inline-block w-3 h-3 rounded-sm bg-teal-600"></span></span>
  </div>

  <div class="p-5 pt-3">
    <ul class="space-y-2">
      {rows.map((c) => (
        <li class="flex items-center gap-3">
          <div class="w-16 flex-shrink-0">
            <span class="font-mono font-bold text-sm text-dark-900">{c.code}</span>
            <span class="block text-xs text-dark-600">{c.name}</span>
          </div>

          <!-- 中央 0 基準 ダイバージング バー -->
          <div class="flex-1 flex items-stretch h-6 relative" role="img"
               aria-label={`${c.name} ${c.bias >= 0 ? '強い (買い傾向)' : '弱い (売り傾向)'} ${c.bias >= 0 ? '+' : ''}${c.bias}`}>
            <!-- 左半分 (負 = 弱い / 右寄せで中央から左へ伸びる) -->
            <div class="w-1/2 flex justify-end items-center">
              {c.bias < 0 && (
                <div class={`h-6 bg-red-400 rounded-l`} style={`width: ${pct(c.bias)}%`}></div>
              )}
            </div>
            <!-- 中央線 -->
            <div class="absolute left-1/2 top-0 bottom-0 w-px bg-dark-300 -translate-x-1/2"></div>
            <!-- 右半分 (正 = 強い / 左寄せで中央から右へ伸びる) -->
            <div class="w-1/2 flex justify-start items-center">
              {c.bias > 0 && (
                <div class={`h-6 bg-teal-600 rounded-r`} style={`width: ${pct(c.bias)}%`}></div>
              )}
            </div>
          </div>

          <span class={`font-mono text-sm font-bold w-12 text-right ${c.bias >= 0 ? 'text-teal-700' : 'text-red-600'}`}>
            {c.bias >= 0 ? '+' : ''}{c.bias}
          </span>
        </li>
      ))}
    </ul>
  </div>

  <footer class="px-5 py-3 border-t border-dark-200 text-xs text-dark-600 leading-relaxed">
    中央 0 を基準に、<strong class="text-teal-700">右 (正) = 強い通貨 (買い傾向)</strong>、<strong class="text-red-600">左 (負) = 弱い通貨 (売り傾向)</strong>。
    強い通貨と弱い通貨の組み合わせが「通貨ペア」を見る際のヒントになります。ECB 公表レート変化率を Z-score 正規化した<strong class="text-dark-900">参考指標</strong>であり、売買判断の助言ではありません。ゴールド (XAUUSD) 単体は <a href="/dashboard/" class="underline text-teal-700">分析ダッシュボード</a>で扱います。
  </footer>
</section>

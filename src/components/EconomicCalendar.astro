---
/**
 * EconomicCalendar.astro — 今後の主要経済指標カレンダー (高インパクト / 当日以降)
 *
 * Source: src/data/economic-calendar.json
 *  - 生成: scripts/fetch-economic-calendar.mjs (Forex Factory 今週+来週 XML)
 *  - 更新: GitHub Actions daily-data-refresh.yml で毎日自動
 *  - データは「当日 0:00 JST 以降」の高インパクトのみ (過去イベントは除外済)
 *
 * 鮮度 UI:
 *  - 取得日時 + 表示期間
 *  - 48h 超: amber 警告 / 5 日超: red 警告
 *  - 本日のイベントは行をハイライト
 */
import data from '../data/economic-calendar.json';

const impactColor = {
  high:   'bg-red-50 text-red-700 border-red-200',
  medium: 'bg-amber-50 text-amber-700 border-amber-200',
  low:    'bg-dark-50 text-dark-700 border-dark-200',
};
const impactLabel = { high: '高', medium: '中', low: '低' };

const weekday = ['日', '月', '火', '水', '木', '金', '土'];
function formatDate(s) {
  const d = new Date(s + 'T00:00:00+09:00');
  return `${d.getMonth() + 1}/${d.getDate()} (${weekday[d.getDay()]})`;
}

// 本日 (JST) の YYYY-MM-DD
const todayJst = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);

// 鮮度判定
const fetchedAt = data._fetched_at ? new Date(data._fetched_at) : null;
const ageHr = fetchedAt ? (Date.now() - fetchedAt.getTime()) / 3600000 : Infinity;
let staleLevel = 'fresh';
if (ageHr > 5 * 24) staleLevel = 'stale';
else if (ageHr > 48) staleLevel = 'warn';

const fetchedJst = fetchedAt
  ? new Date(fetchedAt.getTime() + 9 * 3600 * 1000).toISOString().slice(0, 16).replace('T', ' ')
  : '—';
const staleClass = { fresh: 'text-dark-600', warn: 'text-amber-700 font-bold', stale: 'text-red-700 font-bold' }[staleLevel];
const staleLabel = { fresh: '', warn: ' (48 時間以上前)', stale: ' ⚠ 自動更新が停止している可能性' }[staleLevel];

const events = data.events || [];
---

<section aria-label="今後の主要経済指標" class="mt-10 border border-dark-200 rounded-xl bg-white overflow-hidden">
  <header class="flex flex-wrap items-baseline justify-between gap-2 px-5 py-4 border-b border-dark-200 bg-dark-50">
    <h2 class="font-display font-bold text-lg text-dark-900">今後の主要経済指標 (高インパクト)</h2>
    <p class="text-xs">
      <span class="text-dark-600">{data._window || ''} / JST / 出典: <a href="https://www.forexfactory.com" rel="noopener noreferrer" target="_blank" class="underline text-teal-700">Forex Factory®</a> / </span>
      <span class={staleClass}>取得 <span class="font-mono">{fetchedJst} JST</span>{staleLabel}</span>
    </p>
  </header>

  {staleLevel === 'stale' && (
    <div role="alert" class="mx-5 mt-4 p-3 border border-red-300 bg-red-50 rounded text-xs text-red-800 leading-relaxed">
      ⚠ <strong>本データは 5 日以上更新されていません</strong>。自動更新ワークフローが停止している可能性があります。最新は <a href="https://www.forexfactory.com/calendar" class="underline">Forex Factory</a> で確認してください。
    </div>
  )}

  {events.length === 0 ? (
    <div class="px-5 py-8 text-center text-sm text-dark-600">
      今後の高インパクト指標は現在ありません (次回取得で更新されます)。
    </div>
  ) : (
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="text-xs text-dark-700 bg-dark-50/50">
          <tr>
            <th class="text-left px-4 py-2 font-display font-semibold">日付</th>
            <th class="text-left px-4 py-2 font-display font-semibold">時刻 (JST)</th>
            <th class="text-left px-4 py-2 font-display font-semibold">通貨</th>
            <th class="text-left px-4 py-2 font-display font-semibold">影響度</th>
            <th class="text-left px-4 py-2 font-display font-semibold">指標</th>
            <th class="text-right px-4 py-2 font-display font-semibold">前回</th>
            <th class="text-right px-4 py-2 font-display font-semibold">予想</th>
          </tr>
        </thead>
        <tbody>
          {events.map((ev) => (
            <tr class={`border-t border-dark-100 transition ${ev.date === todayJst ? 'bg-teal-50/60' : 'hover:bg-teal-50/30'}`}>
              <td class="px-4 py-2 text-dark-700 whitespace-nowrap">
                {formatDate(ev.date)}
                {ev.date === todayJst && <span class="ml-1 px-1.5 py-0.5 text-[10px] bg-teal-700 text-white rounded">本日</span>}
              </td>
              <td class="px-4 py-2 font-mono text-dark-900 whitespace-nowrap">{ev.time}</td>
              <td class="px-4 py-2 font-mono font-bold text-teal-700 whitespace-nowrap">{ev.currency}</td>
              <td class="px-4 py-2 whitespace-nowrap">
                <span class={`inline-block px-2 py-0.5 text-xs border rounded ${impactColor[ev.impact]}`}>{impactLabel[ev.impact]}</span>
              </td>
              <td class="px-4 py-2 text-dark-900">{ev.title}</td>
              <td class="px-4 py-2 text-right font-mono text-dark-700 whitespace-nowrap">{ev.previous}</td>
              <td class="px-4 py-2 text-right font-mono text-dark-900 whitespace-nowrap">{ev.forecast}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <footer class="px-5 py-3 border-t border-dark-200 text-xs text-dark-600 leading-relaxed">
    今週+来週の高インパクト指標を毎日自動取得し、当日以降のみを時系列で表示しています。発表値は参考情報であり、投資判断の助言ではありません。最新・正確な情報は <a href="https://www.forexfactory.com/calendar" rel="noopener noreferrer" target="_blank" class="underline text-teal-700">Forex Factory</a> でご確認ください。
  </footer>
</section>

---
/**
 * BlogArticle.astro — ブログ個別記事の共通ラッパ
 *
 * 役割:
 *  - BaseLayout を内包し、記事用の SEO / Article JSON-LD / BreadcrumbList を自動生成
 *  - パンくず・記事ヘッダ (カテゴリ/日付/読了時間)・法的フッタを共通化
 *  - 本文は <slot /> で受け取る (HTML 直書き)
 *
 * blog-posts.json のメタと一致させること (slug / title / category / date)。
 */
import BaseLayout from './BaseLayout.astro';
import posts from '../data/blog-posts.json';

interface Props {
  slug: string;
  description?: string;
  faq?: Array<{ q: string; a: string }>;
}
const { slug, description, faq = [] } = Astro.props;

const post = posts.posts.find((p) => p.slug === slug);
if (!post) throw new Error(`blog-posts.json に slug "${slug}" がありません`);

const catName = posts._categories[post.category as keyof typeof posts._categories] || post.category;
const url = `https://tcharton.com/blog/${post.slug}/`;
const desc = description || post.excerpt;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://tcharton.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://tcharton.com/blog/' },
    { '@type': 'ListItem', position: 3, name: post.title, item: url },
  ],
};

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': `${url}#article`,
  headline: post.title,
  description: desc,
  url,
  datePublished: post.date,
  dateModified: post.date,
  inLanguage: 'ja',
  articleSection: catName,
  author: { '@id': 'https://tcharton.com/#organization' },
  publisher: { '@id': 'https://tcharton.com/#organization' },
  mainEntityOfPage: url,
};

// FAQPage JSON-LD (faq 指定時のみ / ロングテール・強調スニペット獲得)
const faqJsonLd = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${url}#faq`,
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const extraJsonLd = `<script type="application/ld+json">${JSON.stringify(breadcrumbJsonLd)}</script><script type="application/ld+json">${JSON.stringify(articleJsonLd)}</script>${faqJsonLd ? `<script type="application/ld+json">${JSON.stringify(faqJsonLd)}</script>` : ''}`;

const dateJp = post.date.replace(/^(\d+)-(\d+)-(\d+)$/, '$1 年 $2 月 $3 日');
---

<BaseLayout
  title={`${post.title} | T.C.HARTON`}
  description={desc}
  canonicalPath={`/blog/${post.slug}/`}
  ogType="article"
  ogImage="/og/blog.png"
  ogImageAlt={`${post.title} | T.C.HARTON`}
  keywords={post.keywords}
  extraJsonLd={extraJsonLd}
>
  <nav aria-label="パンくず" class="text-xs text-dark-600 mb-6">
    <a href="/" class="hover:text-teal-700">ホーム</a>
    <span aria-hidden="true" class="mx-2">/</span>
    <a href="/blog/" class="hover:text-teal-700">Blog</a>
    <span aria-hidden="true" class="mx-2">/</span>
    <span aria-current="page">{post.title}</span>
  </nav>

  <header>
    <div class="flex flex-wrap items-center gap-3 text-xs">
      <span class="px-2 py-0.5 bg-teal-50 text-teal-700 border border-teal-200 rounded font-display font-bold">{catName}</span>
      <time datetime={post.date} class="text-dark-600">{dateJp}</time>
      <span class="text-dark-400">·</span>
      <span class="text-dark-600">約 {post.readingMin} 分</span>
    </div>
    <h1 class="mt-4 font-display text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-tight text-dark-900 leading-tight">
      {post.title}
    </h1>
    <p id="summary" class="mt-4 text-dark-700 leading-relaxed">{post.excerpt}</p>
  </header>

  <!-- 記事本文 (他ページのカード様式に統一: 白背景 + 枠 + 角丸 + パディング) -->
  <article class="prose-fx mt-10 p-6 sm:p-8 lg:p-10 border border-dark-200 rounded-xl bg-white">
    <slot />
  </article>

  {faq.length > 0 && (
    <section aria-label="よくある質問" class="prose-fx mt-8 p-6 sm:p-8 border border-dark-200 rounded-xl bg-white">
      <h2>よくある質問 (FAQ)</h2>
      <dl class="not-prose mt-4 space-y-4">
        {faq.map((f) => (
          <div class="border-b border-dark-100 pb-4 last:border-0 last:pb-0">
            <dt class="font-display font-bold text-dark-900 flex gap-2">
              <span class="text-teal-700" aria-hidden="true">Q.</span><span>{f.q}</span>
            </dt>
            <dd class="mt-2 text-sm text-dark-700 leading-relaxed flex gap-2">
              <span class="text-teal-700 font-bold" aria-hidden="true">A.</span><span>{f.a}</span>
            </dd>
          </div>
        ))}
      </dl>
    </section>
  )}

  <!-- 法的フッタ (全記事共通) -->
  <footer class="mt-12 p-5 border border-dark-200 rounded-xl bg-dark-50 text-xs text-dark-600 leading-relaxed">
    本記事は MT5-Python Trading Dashboard の機能・ロジック解説および裁量トレードの<strong class="text-dark-900">教育目的</strong>で執筆しています。
    特定の売買タイミング・銘柄の推奨ではなく、投資助言業 (金商法 §29) には該当しません。
    数値・指標は市場全体から計算した客観値であり、将来の成果を保証しません。FX 取引は元本を超える損失が生じる可能性があり、最終判断と結果は閲覧者ご自身の自己責任となります。
    詳細は <a href="/legal/disclaimer/" class="underline text-teal-700">免責事項</a> を参照してください。
  </footer>

  <div class="mt-8">
    <a href="/blog/" class="text-sm text-teal-700 font-bold hover:underline">← Blog 一覧に戻る</a>
  </div>
</BaseLayout>

<!-- prose-fx スタイルは src/styles/global.css に集約 (blog/method 共通) -->

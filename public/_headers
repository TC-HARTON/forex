/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-Robots-Tag: index, follow

# 注: CSP は各ページの BaseLayout 内 meta http-equiv に定義済み (form-action 'self' https://api.web3forms.com 含む)。
#     _headers 側に CSP を重複定義すると AND 合成で競合するため、ここには置かない。

# --- ハッシュ付き静的アセット: 1 年 immutable ---
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# --- 画像・OG: 30 日 ---
/og/*
  Cache-Control: public, max-age=2592000
/ceo.webp
  Cache-Control: public, max-age=2592000

# --- メタテキスト: 1 時間 (更新即反映に近い) ---
/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8
/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8
/rss.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

# --- HTML: 常に再検証 / edge は 1 時間 ---
/*.html
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=3600
